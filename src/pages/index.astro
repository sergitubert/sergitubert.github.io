---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="container header-inner">
      <a class="wordmark" href="/">hi, I'm Sergi Tubert</a>
      <nav class="nav" aria-label="Primary">
        <a
          href="https://github.com/sergitubert"
          target="_blank"
          rel="noopener noreferrer">github</a
        >
        <a
          href="https://linkedin.com/in/sergitubert"
          target="_blank"
          rel="noopener noreferrer">linkedin</a
        >
        <a href="./cv.pdf" target="_blank" rel="noopener noreferrer">resume</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <!-- Hero -->
    <section class="container hero">
      <p class="eyebrow">Software engineer</p>
      <h1 class="display" aria-label="Building systems that are meant to last">
        <span id="hero-display"></span><span id="hero-cursor" aria-hidden="true"
          >|</span
        >
      </h1>
      <p class="eyebrow">
        Node.js • React • Typescript • Azure • Hexagonal Architecture •
        Event-Driven Architecture
      </p>
    </section>

    <hr class="container rule" />

    <!-- Connect -->
    <section id="contact" class="container section contact">
      <h2 class="connect-heading">connect</h2>
      <p class="connect-text">
        follow me on <a
          href="https://x.com/sergiitubert"
          target="_blank"
          rel="noopener noreferrer">x</a
        >, view my code on <a
          href="https://github.com/sergitubert"
          target="_blank"
          rel="noopener noreferrer">github</a
        >, have a <a
          href="https://linkedin.com/in/sergitubert"
          target="_blank"
          rel="noopener noreferrer">quick chat</a
        > with me, or email me at <a href="mailto:stubertsabater@gmail.com"
          >stubertsabater@gmail.com</a
        >
      </p>
    </section>
  </main>
</Layout>

<script>
  import { animate } from "motion";

  const el = document.getElementById("hero-display")!;
  const cursor = document.getElementById("hero-cursor")!;

  animate(
    cursor,
    { opacity: [1, 0] },
    {
      duration: 0.6,
      repeat: Infinity,
      direction: "alternate",
      easing: "steps(1, end)",
    },
  );

  const strings = [
    "Full-stack engineer. Backend at heart.",
    "Building maintainable systems that are meant to last.",
  ];

  const delay = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

  async function typewriter() {
    let idx = 0;
    while (true) {
      const text = strings[idx];
      for (let i = 0; i <= text.length; i++) {
        el.textContent = text.slice(0, i);
        await delay(55);
      }
      await delay(2200);
      for (let i = text.length; i >= 0; i--) {
        el.textContent = text.slice(0, i);
        await delay(28);
      }
      await delay(400);
      idx = (idx + 1) % strings.length;
    }
  }

  typewriter();
</script>

<style>
  .container {
    width: 100%;
    max-width: var(--max-width-page);
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  @media (min-width: 768px) {
    .container {
      padding-inline: var(--space-8);
    }
  }

  .skip-link {
    position: absolute;
    left: var(--space-4);
    top: var(--space-4);
    padding: var(--space-2) var(--space-3);
    background: var(--bg-inverse);
    color: var(--text-inverse);
    border-radius: var(--radius-md);
    transform: translateY(-200%);
    transition: transform var(--duration-normal) var(--ease-default);
    z-index: var(--z-sticky);
  }
  .skip-link:focus {
    transform: translateY(0);
    color: var(--text-inverse);
  }

  /* ── Header ──────────────────────────────────────────────────────────── */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .wordmark {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    color: var(--text-primary);
    text-decoration: none;
  }
  .nav {
    display: flex;
    gap: var(--space-6);
  }
  .nav a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
  }
  .nav a:hover {
    color: var(--text-primary);
  }
  @media (max-width: 520px) {
    .nav {
      gap: var(--space-4);
    }
    .nav a {
      font-size: var(--text-xs);
    }
  }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    color: var(--text-tertiary);
    margin-bottom: var(--space-5);
  }
  .display + .eyebrow {
    margin-top: var(--space-8);
    font-style: italic;
  }
  .hero {
    padding-block: var(--space-24) var(--space-20);
  }
  .display {
    font-family: var(--font-display);
    font-weight: var(--display-weight);
    letter-spacing: var(--display-tracking);
    line-height: var(--display-leading);
    font-size: clamp(var(--text-4xl), 6vw, var(--text-6xl));
  }
  .lede {
    margin-top: var(--space-6);
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
  .actions {
    margin-top: var(--space-8);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ── Buttons ─────────────────────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    height: 36px;
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
    border-radius: var(--radius-md);
    border: none;
    text-decoration: none;
    white-space: nowrap;
    transition:
      background-color var(--duration-fast) var(--ease-default),
      color var(--duration-fast) var(--ease-default);
  }
  .btn-lg {
    height: 40px;
    padding: var(--space-2_5) var(--space-5);
    font-size: var(--text-base);
    font-family: var(--font-mono);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--accent-fg);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    color: var(--accent-fg);
  }
  .btn-primary:active {
    background: var(--accent-active);
  }
  .btn-ghost {
    background: transparent;
    color: var(--text-primary);
  }
  .btn-ghost:hover {
    background: var(--ghost-hover);
    color: var(--text-primary);
  }

  /* ── Rule & Section ──────────────────────────────────────────────────── */
  .rule {
    border: none;
    border-top: 1px solid var(--border);
  }
  .section {
    padding-block: var(--space-20);
  }
  .section-head {
    margin-bottom: var(--space-10);
  }
  .section-head h2 {
    font-size: var(--text-3xl);
  }
  .section-meta {
    margin-top: var(--space-2);
    color: var(--text-secondary);
  }

  /* ── Project grid ────────────────────────────────────────────────────── */
  .project-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
  @media (min-width: 720px) {
    .project-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition:
      box-shadow var(--duration-normal) var(--ease-default),
      border-color var(--duration-normal) var(--ease-default);
  }
  .project-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    text-decoration: none;
    color: var(--text-primary);
  }
  .project-card:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--border-strong);
    color: var(--text-primary);
  }
  .project-name {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
  }
  .project-desc {
    color: var(--text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }
  .tags {
    margin-top: auto;
    padding-top: var(--space-2);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .tag {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1;
    padding: var(--space-1) var(--space-2_5);
    border-radius: var(--radius-md);
    background: var(--bg-muted);
    color: var(--text-secondary);
  }

  /* ── Writing list ────────────────────────────────────────────────────── */
  .writing-list {
    list-style: none;
    border-top: 1px solid var(--border);
  }
  .writing-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) var(--space-1);
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: var(--text-primary);
  }
  .writing-row:hover {
    color: var(--text-primary);
    background: var(--bg-subtle);
  }
  .writing-title {
    font-size: var(--text-lg);
  }
  .writing-date {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  /* ── About (inverse) ─────────────────────────────────────────────────── */
  .inverse-block {
    background: var(--bg-inverse);
    color: var(--text-inverse);
    padding-block: var(--space-24);
  }
  .about-inner {
    max-width: var(--max-width-prose);
  }
  .eyebrow-inverse {
    color: var(--gray-500);
  }
  .about-text {
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--gray-200);
  }
  .about-text + .about-text {
    margin-top: var(--space-6);
  }

  /* ── Typewriter cursor ───────────────────────────────────────────────── */
  #hero-cursor {
    display: inline;
    margin-left: 1px;
    color: var(--accent);
  }

  /* ── Contact ─────────────────────────────────────────────────────────── */
  .connect-heading {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }
  .connect-text {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    max-width: var(--max-width-prose);
  }
  .connect-text a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .connect-text a:hover {
    color: var(--accent-hover);
  }

  /* ── Footer ──────────────────────────────────────────────────────────── */
  .site-footer {
    border-top: 1px solid var(--border);
    padding-block: var(--space-10);
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    justify-content: space-between;
  }
  .footer-mark {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-tertiary);
  }
  .footer-links {
    display: flex;
    gap: var(--space-5);
  }
  .footer-links a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
  }
  .footer-links a:hover {
    color: var(--text-primary);
  }
</style>
